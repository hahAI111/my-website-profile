# ============================================================
# Environment Variables for Portfolio Website
# Copy this file to .env and fill in your values
# ============================================================

# ── Database (Required) ────────────────────────────────────
# PostgreSQL connection string — at least one of these must be set.
# Azure format:
# AZURE_POSTGRESQL_CONNECTIONSTRING=Server=myserver.postgres.database.azure.com;Database=mydb;User Id=myuser;Password=mypass
# Standard format:
AZURE_POSTGRESQL_CONNECTIONSTRING=host=localhost dbname=portfoliodb user=postgres password=postgres

# ── Redis Cache (Optional) ─────────────────────────────────
# If not set, the app works without caching (slower but functional).
# Azure format:
# AZURE_REDIS_CONNECTIONSTRING=mycache.redis.cache.windows.net:6380,password=xxx,ssl=True,abortConnect=False
# Standard format:
# AZURE_REDIS_CONNECTIONSTRING=redis://localhost:6379/0

# ── Flask Secret Key (Recommended) ─────────────────────────
# Used for session encryption. If not set, a random key is generated on each restart
# (which invalidates all existing sessions).
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=your-random-secret-key-here

# ── Admin Authentication ───────────────────────────────────
# Username for admin dashboard login (default: admin)
# ADMIN_USER=admin

# Option 1 (Recommended): bcrypt hash of admin password
# Generate with: python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
# ADMIN_PASS_HASH=$2b$12$...your-bcrypt-hash...

# Option 2 (Development only): plain text password
# ⚠️ DO NOT use this in production — use ADMIN_PASS_HASH instead
ADMIN_PASS=admin123

# ── Email Notifications (Optional) ─────────────────────────
# Contact form messages are always saved to the database.
# These settings enable email forwarding to the site owner.
# OWNER_EMAIL=you@gmail.com
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-16-char-app-password

# ── GitHub Integration (Optional) ──────────────────────────
# Used to sync your GitHub repos to the Projects page.
# GITHUB_USERNAME=your-github-username
# GITHUB_TOKEN=ghp_your-personal-access-token

# Auto-sync interval in seconds (default: 21600 = 6 hours)
# GITHUB_SYNC_INTERVAL=21600
